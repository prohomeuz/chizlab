# Landing production environment (copy to .env on the server).
# These are baked into the client bundle at build time, so a change needs a rebuild.

# Public API (already running on the server)
NEXT_PUBLIC_API_URL=https://api.chizlab.uz

# Origin sent with public API requests — must be allowed by the API's origin guard
NEXT_PUBLIC_SITE_ORIGIN=https://chizlab.uz
